# Copy to .env.local and fill in.
# Get values from: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY-HERE

# SERVER-ONLY: Service role key — kreves for backoffice-funksjoner som å
# opprette nye brukere fra UI. Hentes fra Supabase → Settings → API →
# "service_role" key. ALDRI commit denne, og ALDRI bruk i klient-kode.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: only if you need to send transactional email from Server Actions.
# Without this, MVP will skip sending emails (still creates in-app notifications).
# RESEND_API_KEY=re_xxx

# Optional: site URL used in invite emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
